# PlusUltra Backend - Environment Variables Configuration
# Copy this file to .env and fill in your values

# ================================
# Application Configuration
# ================================
NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# ================================
# Database Configuration
# ================================
# PostgreSQL 17 with pgvector17 (Homebrew)
DATABASE_URL=postgresql://your-db-user:your-db-password@localhost:5432/plusultra

# Redis Configuration (for caching and job queue)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ================================
# Supabase Configuration
# ================================
# Main Supabase Project
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase Management API (for provisioning new projects)
SUPABASE_ACCESS_TOKEN=your-management-api-token
SUPABASE_ORG_ID=your-organization-id
SUPABASE_REGION=us-east-1

# ================================
# AI Model Providers
# ================================
# OpenAI (GPT-4/5 - TCI Layer 3: Historical Pattern Matching)
OPENAI_API_KEY=your-openai-api-key
OPENAI_ORG_ID=your-org-id

# Anthropic Claude (TCI Layer 2: Causal Analysis + Layer 6: Implementation)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Google Gemini (TCI Layer 5: Cross-Model Synthesis)
GOOGLE_API_KEY=your-google-api-key

# xAI Grok (TCI Layer 4: Symbolic Logic Verification)
XAI_API_KEY=your-xai-api-key
GROK_API_KEY=your-grok-api-key
GROK_API_URL=https://api.x.ai/v1/chat/completions

# DeepSeek (TCI Layer 1: Visual Pattern Recognition)
DEEPSEEK_API_KEY=your-deepseek-api-key

# Kimi 2 / Moonshot (TCI Layer 1b: Video/Animation Understanding)
# Specialized for: UI interaction videos, CSS animations, motion design, visual effects
KIMI_API_KEY=your-kimi-api-key
KIMI_API_URL=https://api.moonshot.cn/v1

# ================================
# Task Agents (Non-Voting)
# ================================
# These agents execute creative/generative tasks but don't participate in TCI voting

# Nano Banana (Image Generation)
# Specialized for: App icons, screenshots, feature graphics, UI assets, marketing materials
NANO_BANANA_API_KEY=your-nano-banana-api-key
NANO_BANANA_API_URL=https://api.nanobanana.ai/v1

# Kling 2.6 (Video Generation)
# Specialized for: App previews, promo videos, tutorials, marketing videos
KLING_API_KEY=your-kling-api-key
KLING_API_URL=https://api.kling.ai/v2.6

# ================================
# Storage Configuration
# ================================
# Cloudflare R2 (S3-compatible)
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=plusultra-artifacts
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# Cloudflare R2 for Asset Storage (App Icons, Screenshots, etc.)
CLOUDFLARE_R2_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_R2_ACCESS_KEY_ID=your-r2-access-key-id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
CLOUDFLARE_R2_BUCKET_NAME=plusultra-app-assets
CLOUDFLARE_R2_CDN_DOMAIN=assets.plusultra.dev

# Cloudflare R2 for Subdomain Hosting (deployed apps/sites)
CLOUDFLARE_R2_HOSTING_BUCKET=plusultra-hosting

# ================================
# Cloudflare DNS & SSL Configuration
# ================================
# Used for subdomain hosting (*.apps.plusultra.dev, *.sites.plusultra.dev)
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
CLOUDFLARE_ZONE_ID=your-cloudflare-zone-id
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id

# ================================
# Vector Database
# ================================
# Pinecone (Recommended for TCI pattern storage and semantic search)
# Better performance for our multi-model stack
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_ENVIRONMENT=us-east-1-aws
PINECONE_INDEX_NAME=plusultra-tci-patterns

# Or Weaviate
WEAVIATE_URL=http://localhost:8080
WEAVIATE_API_KEY=your-weaviate-api-key

# ================================
# Graph Database (Neo4j)
# ================================
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-neo4j-password
NEO4J_DATABASE=neo4j

# ================================
# HuggingFace (for Starcoder)
# ================================
HUGGINGFACE_API_KEY=your-huggingface-api-key

# ================================
# Collaboration Services
# ================================
# Liveblocks (real-time collaboration)
LIVEBLOCKS_PUBLIC_KEY=your-liveblocks-public-key
LIVEBLOCKS_SECRET_KEY=your-liveblocks-secret-key

# Y.js WebSocket Server
YJS_WEBSOCKET_URL=wss://your-yjs-server.com

# ================================
# Payment & Billing
# ================================
# Stripe
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=your-webhook-secret

# ================================
# GitHub Integration
# ================================
# OAuth App Configuration
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URI=http://localhost:3000/auth/github/callback

# GitHub Personal Access Token (for repository operations)
GITHUB_ACCESS_TOKEN=your-personal-access-token

# GitHub App (alternative to OAuth, for advanced features)
GITHUB_APP_ID=your-app-id
GITHUB_APP_PRIVATE_KEY_PATH=/path/to/private-key.pem

# ================================
# Mobile Build Services
# ================================
# Expo Application Services (EAS)
EAS_PROJECT_ID=your-eas-project-id
EXPO_TOKEN=your-expo-token

# Apple App Store
APPLE_ID=your-apple-id
APPLE_APP_SPECIFIC_PASSWORD=your-app-specific-password
APPLE_TEAM_ID=your-team-id
APPLE_KEY_ID=your-key-id
APPLE_ISSUER_ID=your-issuer-id
APPLE_PRIVATE_KEY_PATH=/path/to/AuthKey.p8
# Or inline private key (for Docker/CI/CD)
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour Key Here\n-----END PRIVATE KEY-----"

# Google Play Store
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=/path/to/service-account-key.json
GOOGLE_PACKAGE_NAME=com.yourcompany.app
# Or inline service account key (for Docker/CI/CD)
GOOGLE_SERVICE_ACCOUNT_KEY="-----BEGIN PRIVATE KEY-----\nYour Key Here\n-----END PRIVATE KEY-----"
ANDROID_PACKAGE_NAME=com.yourcompany.app

# ================================
# Asset Generation (Canva)
# ================================
# Canva API for generating app icons, screenshots, and feature graphics
CANVA_API_KEY=your-canva-api-key
CANVA_BRAND_ID=your-brand-id-optional
# Asset generation defaults
CANVA_DEFAULT_STYLE=modern
CANVA_DEFAULT_THEME=professional

# ================================
# Monitoring & Observability
# ================================
# Sentry (Error Tracking)
SENTRY_DSN=your-sentry-dsn

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=plusultra-backend

# PostHog (Analytics)
POSTHOG_API_KEY=your-posthog-api-key
POSTHOG_HOST=https://app.posthog.com

# ================================
# Security & Authentication
# ================================
# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRES_IN=7d

# Session Secret
SESSION_SECRET=your-session-secret-min-32-chars

# ================================
# Email Configuration
# ================================
EMAIL_HOST=your-email-smtp-host
EMAIL_PORT=587
EMAIL_USER=your-email-username
EMAIL_PASSWORD=your-email-password
CONTACT_FORM_RECIPIENT=your-support-email@example.com

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ================================
# Feature Flags
# ================================
ENABLE_TCI=true
ENABLE_COLLABORATION=true
ENABLE_AUTO_DEPLOY=true
ENABLE_AI_PRODUCT_MANAGER=true

# ================================
# Rate Limiting
# ================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ================================
# Job Queue Configuration
# ================================
JOB_QUEUE_MIN_WORKERS=1
JOB_QUEUE_MAX_WORKERS=10
JOB_QUEUE_SCALE_UP_THRESHOLD=10
JOB_QUEUE_SCALE_DOWN_THRESHOLD=2

# ================================
# Token Economy
# ================================
# Token Pool Configuration
FREE_TIER_TOKENS=50000
STARTER_TIER_TOKENS=250000
PRO_TIER_TOKENS=1000000
ENTERPRISE_TIER_TOKENS=10000000

# Model Token Costs (per 1K tokens)
GPT5_COST_PER_1K=0.03
CLAUDE_COST_PER_1K=0.025
GEMINI_COST_PER_1K=0.02
STARCODER_COST_PER_1K=0.01

# ================================
# Docker & Sandbox Configuration
# ================================
# Docker connection
DOCKER_SOCKET_PATH=/var/run/docker.sock
DOCKER_HOST=unix:///var/run/docker.sock

# Workspace paths
WORKSPACE_BASE_PATH=/tmp/plusultra-workspaces
SANDBOX_TEMP_DIR=/tmp/plusultra-sandbox

# Port allocation for preview servers
PREVIEW_PORT_RANGE_START=3000
PREVIEW_PORT_RANGE_END=4000

# Resource limits per workspace
DEFAULT_MEMORY_LIMIT=1g
DEFAULT_CPU_LIMIT=1
WORKSPACE_TTL=3600

# Timeouts
SANDBOX_DEFAULT_TIMEOUT=300000
SANDBOX_STARTUP_TIMEOUT=60000

# TCI Sandbox Monitoring
TCI_AUTO_FIX_ENABLED=true
TCI_MONITOR_INTERVAL=10000
TCI_MAX_AUTO_FIXES_PER_HOUR=10

# Cleanup
WORKSPACE_CLEANUP_INTERVAL=300000
WORKSPACE_MAX_INACTIVE_TIME=3600000

# ================================
# Compliance & Governance
# ================================
ENABLE_AUDIT_LOGGING=true
AUDIT_LOG_RETENTION_DAYS=365
DATA_RETENTION_DAYS=90
ENABLE_GDPR_COMPLIANCE=true
ENABLE_HIPAA_COMPLIANCE=false

# ================================
# Development Only
# ================================
DEBUG=false
LOG_LEVEL=info
ENABLE_API_DOCS=true
